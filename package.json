{
  "name": "iobroker.victronadapter",
  "version": "0.6.9",
  "description": "ioBroker adapter for Victron GX and Cerbo GX systems via Modbus TCP with checker-compatible admin layout and robust scan handling.",
  "author": "FreeProgrammer1",
  "license": "MIT",
  "homepage": "https://github.com/FreeProgrammer1/ioBroker.victronadapter#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/FreeProgrammer1/ioBroker.victronadapter.git"
  },
  "bugs": {
    "url": "https://github.com/FreeProgrammer1/ioBroker.victronadapter/issues"
  },
  "keywords": [
    "ioBroker",
    "victron",
    "cerbo",
    "gx",
    "modbus",
    "modbus-tcp",
    "energy",
    "ess",
    "pv",
    "battery",
    "solar"
  ],
  "main": "main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node main.js",
    "test": "npm run test:js && npm run test:unit && npm run test:package",
    "test:js": "node --check main.js && node --check lib/modbusClient.js && node --check lib/registerMap.js && node --check lovelace/victronadapter-card.js",
    "test:unit": "node --test test/*.test.js",
    "test:package": "npm pack --dry-run",
    "lint": "eslint .",
    "adapter-check": "npx --yes @iobroker/repochecker https://github.com/FreeProgrammer1/ioBroker.victronadapter --local",
    "release": "release-script"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1"
  },
  "devDependencies": {
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.0.0",
    "@alcalzone/release-script": "^3.8.0"
  },
  "files": [
    "admin",
    "lib",
    "lovelace",
    "test",
    "main.js",
    "io-package.json",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "tsconfig.json",
    "eslint.config.mjs",
    "prettier.config.mjs"
  ]
}
